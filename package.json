    "test": "turbo run test",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "@yarnpkg/types": "^4.0.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.9.6"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "yarn@4.12.0"
